[Unit]
Description=VPS Monitor Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/vps-monitor
ExecStart=/opt/vps-monitor/.venv/bin/python /opt/vps-monitor/agent.py --config /etc/vps-monitor-agent.toml
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
